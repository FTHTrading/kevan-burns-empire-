# ─────────────────────────────────────────────────────────────────
# Burns Empire — Environment Variables
# Copy to .env.local and fill in values
# ─────────────────────────────────────────────────────────────────

# Cloudflare API (deployment to portfolio.unykorn.org)
CLOUDFLARE_API_TOKEN=

# OpenAI
OPENAI_API_KEY=

# ElevenLabs Text-to-Speech (enables audio narration on system pages)
# Get your API key at https://elevenlabs.io → Profile → API Keys
NEXT_PUBLIC_ELEVENLABS_API_KEY=

# Voice ID (optional — defaults to Rachel if not set)
# Browse voices at https://elevenlabs.io/voice-library
# NEXT_PUBLIC_ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
