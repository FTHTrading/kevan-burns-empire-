{
  "name": "kevan-burns-empire",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ci": "vitest run --reporter=verbose",
    "check": "node scripts/system-check.mjs",
    "check:full": "node scripts/system-check.mjs --full",
    "check:ci": "node scripts/system-check.mjs --ci",
    "check:json": "node scripts/system-check.mjs --json",
    "check:fix": "node scripts/system-check.mjs --fix",
    "audit": "npx tsx scripts/full-audit.mjs",
    "audit:platforms": "node scripts/audit-platforms.mjs",
    "validate:platforms": "node scripts/audit-platforms.mjs --validate",
    "deploy": "powershell -ExecutionPolicy Bypass -File deploy-cloudflare.ps1",
    "deploy:skip-build": "powershell -ExecutionPolicy Bypass -File deploy-cloudflare.ps1 -SkipBuild",
    "deploy:ipfs": "powershell -ExecutionPolicy Bypass -File deploy-ipfs.ps1",
    "tokens": "node scripts/list-tokens.mjs",
    "tokens:expired": "node scripts/list-tokens.mjs --expired",
    "access-log": "node scripts/access-log.mjs",
    "access-log:today": "node scripts/access-log.mjs --today",
    "issue-token": "node scripts/issue-token.mjs"
  },
  "dependencies": {
    "framer-motion": "^12.34.3",
    "lucide-react": "^0.575.0",
    "next": "14.2.35",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260317.1",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.1"
  }
}
